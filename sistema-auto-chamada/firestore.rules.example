rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuários: cada um pode ler/escrever apenas o próprio documento (id = auth.uid)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Cursos: usuários autenticados podem ler; podem atualizar para se adicionar em studentIds ou professorIds
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow create: if false;
      allow update: if request.auth != null;
      allow delete: if false;
    }
    // Aulas (classes): professores do curso podem gerenciar (ler/escrever)
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }
    // Presenças (attendances): usuários autenticados podem ler; podem criar/atualizar o próprio registro
    match /attendances/{attendanceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
